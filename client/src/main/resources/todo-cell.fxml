<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>

<HBox fx:id="root" alignment="CENTER_LEFT" spacing="15" styleClass="todo-card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <CheckBox fx:id="checkBox" />
    <TextField fx:id="textField" HBox.hgrow="ALWAYS" styleClass="todo-text-field" />
    <Button fx:id="deleteButton" text="Usuń" styleClass="delete-button" />
</HBox>