<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="todotool.client.controller.ClientController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 6 12; -fx-background-radius: 4;">
        <Label text="IP Serwera:" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;" />
        <TextField fx:id="serverIpInput" text="localhost" prefWidth="100" style="-fx-font-size: 11px; -fx-padding: 2 5;" />
        <Button fx:id="connectButton" text="Dołącz do serwera" onAction="#handleConnectToServer" style="-fx-font-size: 11px; -fx-padding: 2 6; -fx-cursor: hand;" />
        <Label fx:id="connectionStatusLabel" text="Offline" style="-fx-font-size: 11px; -fx-text-fill: #ef4444; -fx-font-weight: bold;" />
    </HBox>

    <HBox spacing="15" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 8 12; -fx-background-radius: 4;">

        <VBox spacing="2" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <Label text="Postęp zadań:" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;" />
            <ProgressBar fx:id="taskProgress" progress="0.0" maxWidth="Infinity" style="-fx-accent: #10b981;" />
        </VBox>

        <VBox spacing="3" alignment="CENTER">
            <Label fx:id="pomodoroLabel" text="Pomodoro: 25:00" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>

            <HBox spacing="6" alignment="CENTER">
                <ProgressBar fx:id="pomodoroProgress" progress="0.0" prefWidth="90" />
                <Button fx:id="pomodoroButton" text="Start" onAction="#handlePomodoroToggle"
                        style="-fx-font-size: 10px; -fx-padding: 1px 5px; -fx-cursor: hand;" />
            </HBox>
        </VBox>

    </HBox>
    <HBox spacing="10">
        <TextField fx:id="newTaskInput" HBox.hgrow="ALWAYS" onAction="#handleAddTask"/>
        <Button text="Dodaj" onAction="#handleAddTask" />
    </HBox>
    <ListView fx:id="listView" VBox.vgrow="ALWAYS" />
</VBox>